PYTHON_VERSION=3.11
IMAGE_TAG=latest
LOCAL_UID=1000
LOCAL_GID=1000
POSTGRES_DB=tech_pulse
POSTGRES_USER=techpulse
POSTGRES_PASSWORD=techpulse
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://techpulse:techpulse@postgres:5432/tech_pulse
REQUEST_TIMEOUT=20
USER_AGENT=tech-pulse-engine/2.0
LOG_LEVEL=INFO
DIGEST_PATH=/data/daily_digest.md
DAILY_RUN_HOUR=7
DAILY_RUN_MINUTE=0
MIN_AFRICA_SCORE=0.50
DASHBOARD_PORT=8080
DASHBOARD_TITLE=Tech Pulse Command Center
DASHBOARD_REFRESH_SECONDS=60
INIT_DB_ATTEMPTS=20
INIT_DB_DELAY_SECONDS=3
